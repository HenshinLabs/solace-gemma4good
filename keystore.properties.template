# keystore.properties — DO NOT COMMIT actual values
# Copy this file to keystore.properties and fill in your values.
# Add keystore.properties to .gitignore.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore solace-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias solace
#
# Then set these properties as Gradle properties or environment variables:
#   MASTER_LLM_RELEASE_STORE_FILE=/path/to/solace-release.jks
#   MASTER_LLM_RELEASE_STORE_PASSWORD=your_store_password
#   MASTER_LLM_RELEASE_KEY_ALIAS=solace
#   MASTER_LLM_RELEASE_KEY_PASSWORD=your_key_password
