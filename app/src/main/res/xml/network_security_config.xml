<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for localhost Ollama server -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Allow common local network IPs -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>
    <!-- Allow cleartext for ollama.com API calls -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">ollama.com</domain>
        <domain includeSubdomains="true">huggingface.co</domain>
        <domain includeSubdomains="true">api.github.com</domain>
    </domain-config>
    <!-- Trust system CAs by default -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
